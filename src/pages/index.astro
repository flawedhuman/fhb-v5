---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const collections = ['thoughts', 'art', 'music', 'design-work'] as const;
const posts = (await Promise.all(collections.map((name) => getCollection(name))))
	.flat()
	.filter((post) => !post.data.draft)
	.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title="FHB" description="Your home away from home.">
	{posts.map((post, index) => (
		<PostCard post={post} index={index} total={posts.length} />
	))}
</BaseLayout>